<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.NotesApp" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/md_theme_light_primary</item>
        <item name="colorOnPrimary">@color/md_theme_light_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_light_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_light_onPrimaryContainer</item>
        <item name="colorSecondary">@color/md_theme_light_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_light_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_light_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_light_onSecondaryContainer</item>
        <item name="colorTertiary">@color/md_theme_light_tertiary</item>
        <item name="colorOnTertiary">@color/md_theme_light_onTertiary</item>
        <item name="colorTertiaryContainer">@color/md_theme_light_tertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/md_theme_light_onTertiaryContainer</item>
        <item name="colorError">@color/md_theme_light_error</item>
        <item name="colorOnError">@color/md_theme_light_onError</item>
        <item name="colorErrorContainer">@color/md_theme_light_errorContainer</item>
        <item name="colorOnErrorContainer">@color/md_theme_light_onErrorContainer</item>
        <item name="colorSurface">@color/md_theme_light_surface</item>
        <item name="colorOnSurface">@color/md_theme_light_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_theme_light_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_light_onSurfaceVariant</item>
        <item name="colorOutline">@color/md_theme_light_outline</item>
        <item name="colorOutlineVariant">@color/md_theme_light_outlineVariant</item>
        <item name="android:colorBackground">@color/md_theme_light_background</item>
        <item name="colorOnBackground">@color/md_theme_light_onBackground</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <!-- Rounded shapes -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.NotesApp.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.NotesApp.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.NotesApp.Large</item>
    </style>

    <style name="Theme.NotesApp.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/md_theme_light_primaryContainer</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_note_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.NotesApp</item>
    </style>

    <!-- Shape overrides for softer radius -->
    <style name="ShapeAppearance.NotesApp.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">12dp</item>
    </style>
    <style name="ShapeAppearance.NotesApp.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">18dp</item>
    </style>
    <style name="ShapeAppearance.NotesApp.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSize">24dp</item>
    </style>

    <!-- Typography -->
    <style name="TextAppearance.NotesApp.Title" parent="TextAppearance.Material3.DisplaySmall">
        <item name="android:fontFamily">serif</item>
        <item name="android:letterSpacing">-0.02</item>
        <item name="android:textSize">34sp</item>
    </style>

    <style name="TextAppearance.NotesApp.CardTitle" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.NotesApp.PinnedTitle" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

</resources>

